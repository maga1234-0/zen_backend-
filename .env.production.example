# Production Environment Variables for Hotel PMS Backend
# Copy to .env file and fill in values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=10000
NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION (Supabase)
# ============================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres.hxvhkhwhhfwtthujkahx:YOUR_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:6543/postgres

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_change_this
JWT_EXPIRES_IN=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# Your frontend URL(s), comma-separated for multiple origins
CORS_ORIGIN=https://zen-lyart.vercel.app

# ============================================
# DEPLOYMENT MODE
# ============================================
# Set to "0" for standalone server (Render, Railway, etc.)
# Set to "1" for Vercel serverless mode
VERCEL=0

# ============================================
# OPTIONAL: SCHEDULED JOBS
# ============================================
# Enable/disable scheduled jobs (auto-checkout, notifications, etc.)
ENABLE_SCHEDULED_JOBS=true

# ============================================
# OPTIONAL: LOGGING
# ============================================
LOG_LEVEL=info  # debug, info, warn, error