{
  "name": "hotel-pms-server",
  "version": "1.0.0",
  "description": "Hotel Property Management System - Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:simple": "nodemon src/server-simple.ts",
    "dev:js": "nodemon server.js",
    "build": "tsc",
    "build:simple": "tsc src/server-simple.ts --outDir dist --module commonjs --target ES2020",
    "start": "node server.js",
    "start:simple": "node -r ts-node/register src/server-simple.ts",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.6",
    "@types/pg": "^8.20.0",
    "@vercel/node": "^4.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
